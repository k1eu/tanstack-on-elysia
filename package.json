{
  "name": "app-client",
  "private": true,
  "type": "module",
  "scripts": {
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "NODE_ENV=development bun --bun --watch run server.dev.ts",
    "build": "NODE_ENV=production bun run build:frontend && bun run build:server",
    "build:frontend": "bun --bun vite build",
    "build:server": "bun build --minify-whitespace --minify-syntax --target bun --outfile dist/app server.prod.ts",
    "start": "NODE_ENV=production ./dist/app"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/static": "^1.4.7",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "elysia": "1.4.28",
    "elysia-connect-middleware": "^0.0.6",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "vite-tsconfig-paths": "^6.0.2"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.6.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "web-vitals": "^5.1.0",
    "bun-types": "1.3.10"
  }
}
